# ─────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
#
# LOCAL DEV: uses local Redis via docker-compose (redis://localhost)
# PRODUCTION (Render): uses Upstash — set rediss:// URLs in Render dashboard
# ─────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/premove_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ── Redis (local dev — docker-compose Redis) ──────────────────────
# In production (Render), override these with your Upstash rediss:// URLs
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_TASK_MAX_RETRIES=3

# ── LLM API Keys ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_BASE_URL=https://api.perplexity.ai
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Browser Automation ────────────────────────────────────────────
BROWSER_USE_MODEL=gpt-4o
BROWSER_HEADLESS=True
BROWSER_TIMEOUT=300

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ── API Settings ──────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
API_TITLE=Premove Backend
API_VERSION=1.0.0

# ── Authentication (optional) ─────────────────────────────────────
API_KEY_ENABLED=False
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
